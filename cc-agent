#!/usr/bin/env bash
# cc-agent — launch a file-editing AI sub-agent (DeepSeek/GLM/etc brain,
# full Claude Code tools), talking DIRECT to the provider's Anthropic endpoint.
# Manager (Opus) calls this via Bash to delegate grunt-work coding.
#
# Tools belong to the Claude Code harness, not the model — so a cheap provider
# gets full read/write/edit/run by routing `claude` straight at its endpoint.
#
# Usage:
#   cc-agent <provider> <workdir> "<task>"
#   echo "<task>" | cc-agent <provider> <workdir>
#
#   provider : name of ~/.config/cc-agent/<provider>.env  (default: deepseek)
#   workdir  : dir the agent is confined to (created if missing). Default: $PWD
#   task     : instruction (arg) or piped via stdin
#
# Config file ~/.config/cc-agent/<provider>.env (chmod 600):
#   ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic   # z.ai: NO trailing /v1
#   ANTHROPIC_AUTH_TOKEN=sk-...
#   ANTHROPIC_MODEL=deepseek-v4-pro
#   ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash
#
# Env overrides: CC_AGENT_TIMEOUT (default 300), CC_AGENT_CONFIG_DIR (default ~/.config/cc-agent)
set -euo pipefail

TIMEOUT="${CC_AGENT_TIMEOUT:-300}"
CFG_DIR="${CC_AGENT_CONFIG_DIR:-$HOME/.config/cc-agent}"

provider="${1:-deepseek}"
workdir="${2:-$PWD}"
shift $(( $# >= 2 ? 2 : $# )) || true
task="${*:-}"
[ -z "$task" ] && task="$(cat)"   # fall back to stdin
[ -z "$task" ] && { echo "cc-agent: ERROR no task given" >&2; exit 2; }

cfg="$CFG_DIR/$provider.env"
if [ ! -f "$cfg" ]; then
  echo "cc-agent: ERROR config not found: $cfg" >&2
  echo "  buat dulu (chmod 600) berisi ANTHROPIC_BASE_URL / _AUTH_TOKEN / _MODEL / _SMALL_FAST_MODEL" >&2
  exit 3
fi

# load provider creds
set -a; . "$cfg"; set +a
: "${ANTHROPIC_BASE_URL:?cc-agent: $cfg missing ANTHROPIC_BASE_URL}"
: "${ANTHROPIC_AUTH_TOKEN:?cc-agent: $cfg missing ANTHROPIC_AUTH_TOKEN}"
: "${ANTHROPIC_MODEL:?cc-agent: $cfg missing ANTHROPIC_MODEL}"
export ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_MODEL
[ -n "${ANTHROPIC_SMALL_FAST_MODEL:-}" ] && export ANTHROPIC_SMALL_FAST_MODEL

mkdir -p "$workdir"
log="$workdir/.cc-agent.log"

echo "cc-agent: provider=$provider model=$ANTHROPIC_MODEL workdir=$workdir timeout=${TIMEOUT}s" >&2
timeout "$TIMEOUT" claude --permission-mode bypassPermissions \
  --add-dir "$workdir" -p "Kamu bekerja di direktori $workdir. $task" \
  < /dev/null > "$log" 2>&1
rc=$?

# Hemat token manager: default cuma tampilkan ringkasan (ekor) — laporan agent
# ada di ujung. Full transcript tetap di $log. Set CC_AGENT_FULL=1 untuk dump penuh.
if [ -n "${CC_AGENT_FULL:-}" ]; then
  cat "$log"
else
  lines="${CC_AGENT_TAIL:-20}"
  total=$(wc -l < "$log")
  if [ "$total" -gt "$lines" ]; then
    echo "[... $((total - lines)) baris awal disembunyikan, full: $log ...]"
  fi
  tail -n "$lines" "$log"
fi
echo >&2
[ $rc -ne 0 ] && echo "cc-agent: exit $rc (timeout/err) — cek $log" >&2
exit $rc
