# Simpan sebagai ~/.config/cc-agent/zai.env  (chmod 600)
# PENTING: base_url JANGAN diakhiri /v1 — Claude Code menambah /v1/messages sendiri.
#          Kalau base sudah ada /v1 -> jadi /v1/v1/messages -> error "model may not exist".
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=xxxxxxxx.xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=glm-5.2
ANTHROPIC_SMALL_FAST_MODEL=glm-4.5-air
